{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dkp-standard.com/dkp/schemas/v1/mcp_tool_search.json",
  "title": "search Tool Input",
  "type": "object",
  "required": ["query"],
  "properties": {
    "query": {
      "type": "string",
      "minLength": 1,
      "description": "Full-text search query (BM25)"
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 10,
      "description": "Maximum number of results to return"
    },
    "asset_types": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["chunks", "terms", "rules", "constraints", "eval-cases", "assets", "entity-types", "decision-trees"]
      },
      "description": "Asset types to include in search. If absent, searches all types."
    }
  }
}
